{
	"info": {
		"_postman_id": "messenger-core-v2",
		"name": "Messenger Core API ✅",
		"description": "Backend API demo. Base URL: http://localhost:8080\n\nAll endpoints are pre-configured with real URLs — no variables needed.\n\nFlow: Register → Login → copy token → use in protected requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1️⃣ Register",
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"newuser\",\n    \"password\": \"newpass123\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "http://localhost:8080/auth/register",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["auth", "register"]
				},
				"description": "✅ Expected: 201 Created\n\n```json\n{\n  \"user\": {\n    \"id\": 100000000012,\n    \"username\": \"newuser\",\n    \"role\": \"user\"\n  }\n}\n```\n\n❌ Duplicate username → 409 Conflict"
			}
		},
		{
			"name": "2️⃣ Login (copy token from response!)",
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"alice\",\n    \"password\": \"alice1234\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "http://localhost:8080/auth/login",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["auth", "login"]
				},
				"description": "✅ Expected: 200 OK\n\n```json\n{\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": 100000000007,\n    \"username\": \"alice\",\n    \"role\": \"user\"\n  }\n}\n```\n\n👉 Copy the token value and paste it into the Authorization header of the requests below.\n\n❌ Wrong password → 401 Unauthorized"
			}
		},
		{
			"name": "3️⃣ Login as Admin",
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin1234\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "http://localhost:8080/auth/login",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["auth", "login"]
				},
				"description": "Login as admin (role: admin).\nUse this token for the DELETE /admin/users endpoint."
			}
		},
		{
			"name": "4️⃣ Get All Users [🔒 JWT required]",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer PASTE_YOUR_TOKEN_HERE",
						"description": "Replace PASTE_YOUR_TOKEN_HERE with the token from Login response"
					}
				],
				"url": {
					"raw": "http://localhost:8080/api/users",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "users"]
				},
				"description": "✅ Expected: 200 OK — list of all users\n\n```json\n{\n  \"users\": [\n    { \"id\": 100000000006, \"username\": \"admin\",   \"role\": \"admin\" },\n    { \"id\": 100000000007, \"username\": \"alice\",   \"role\": \"user\" },\n    { \"id\": 100000000008, \"username\": \"bob\",     \"role\": \"user\" },\n    { \"id\": 100000000009, \"username\": \"charlie\", \"role\": \"user\" }\n  ]\n}\n```\n\n❌ No token → 401 Unauthorized"
			}
		},
		{
			"name": "5️⃣ Get Chat History alice↔bob [🔒 JWT]",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer PASTE_YOUR_TOKEN_HERE"
					}
				],
				"url": {
					"raw": "http://localhost:8080/api/messages?contact_id=100000000008&limit=10&offset=0",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "messages"],
					"query": [
						{ "key": "contact_id", "value": "100000000008", "description": "Bob's ID" },
						{ "key": "limit",      "value": "10" },
						{ "key": "offset",     "value": "0" }
					]
				},
				"description": "✅ Expected: 200 OK — conversation between alice and bob\n\n```json\n{\n  \"messages\": [\n    {\n      \"id\": 11,\n      \"from_id\": 100000000007,\n      \"to_id\": 100000000008,\n      \"type\": \"text\",\n      \"content\": \"Hey Bob! How are you?\",\n      \"status\": \"sent\",\n      \"created_at\": \"2026-05-05T21:21:13Z\"\n    },\n    {\n      \"id\": 12,\n      \"from_id\": 100000000008,\n      \"to_id\": 100000000007,\n      \"type\": \"text\",\n      \"content\": \"Hi Alice! I'm doing great, thanks!\",\n      \"status\": \"sent\",\n      \"created_at\": \"2026-05-05T21:21:13Z\"\n    }\n  ]\n}\n```"
			}
		},
		{
			"name": "6️⃣ Get Unread Counts [🔒 JWT]",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer PASTE_YOUR_TOKEN_HERE"
					}
				],
				"url": {
					"raw": "http://localhost:8080/api/messages/unread",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "messages", "unread"]
				},
				"description": "✅ Expected: 200 OK — unread message counts per sender\n\n```json\n{\n  \"counts\": {\n    \"100000000008\": 4,\n    \"100000000009\": 2\n  }\n}\n```\n\nMeaning: alice has 4 unread from bob, 2 from charlie."
			}
		},
		{
			"name": "7️⃣ Get My Contacts [🔒 JWT]",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer PASTE_YOUR_TOKEN_HERE"
					}
				],
				"url": {
					"raw": "http://localhost:8080/api/contacts",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "contacts"]
				},
				"description": "✅ Expected: 200 OK — alice's accepted contacts\n\n```json\n{\n  \"contacts\": [\n    { \"id\": 100000000008, \"username\": \"bob\",     \"role\": \"user\" },\n    { \"id\": 100000000009, \"username\": \"charlie\", \"role\": \"user\" }\n  ]\n}\n```"
			}
		},
		{
			"name": "8️⃣ Send Contact Request [🔒 JWT]",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "Bearer PASTE_YOUR_TOKEN_HERE" },
					{ "key": "Content-Type",  "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"contact_id\": 100000000008\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "http://localhost:8080/api/contacts",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "contacts"]
				},
				"description": "Send a contact request.\n\n✅ Expected: 200 OK\n```json\n{ \"success\": true }\n```"
			}
		},
		{
			"name": "9️⃣ Accept Contact Request [🔒 JWT]",
			"request": {
				"method": "PATCH",
				"header": [
					{ "key": "Authorization", "value": "Bearer PASTE_BOB_TOKEN_HERE" }
				],
				"url": {
					"raw": "http://localhost:8080/api/contacts/100000000007",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "contacts", "100000000007"]
				},
				"description": "Bob accepts alice's request.\nLogin as bob first, use bob's token here.\n\n✅ Expected: 200 OK\n```json\n{ \"success\": true }\n```"
			}
		},
		{
			"name": "🔟 Delete Contact [🔒 JWT]",
			"request": {
				"method": "DELETE",
				"header": [
					{ "key": "Authorization", "value": "Bearer PASTE_YOUR_TOKEN_HERE" }
				],
				"url": {
					"raw": "http://localhost:8080/api/contacts/100000000008",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "contacts", "100000000008"]
				},
				"description": "Remove a contact.\n\n✅ Expected: 200 OK\n```json\n{ \"success\": true }\n```"
			}
		},
		{
			"name": "1️⃣1️⃣ [ADMIN] Delete User [🔒 admin JWT]",
			"request": {
				"method": "DELETE",
				"header": [
					{ "key": "Authorization", "value": "Bearer PASTE_ADMIN_TOKEN_HERE" }
				],
				"url": {
					"raw": "http://localhost:8080/api/admin/users/100000000011",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "admin", "users", "100000000011"]
				},
				"description": "⚠️ ADMIN ONLY — must use admin token!\n\n✅ With admin token → 200 OK:\n```json\n{ \"success\": true }\n```\n\n❌ With regular user token → 403 Forbidden:\n```json\n{\n  \"status\": 403,\n  \"code\": \"FORBIDDEN\",\n  \"message\": \"You don't have permission to access this resource\"\n}\n```"
			}
		},
		{
			"name": "1️⃣2️⃣ [DEMO] No token → 401 Error",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/users",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["api", "users"]
				},
				"description": "Send request WITHOUT Authorization header.\n\n✅ Expected: 401 Unauthorized:\n```json\n{\n  \"status\": 401,\n  \"code\": \"UNAUTHORIZED\",\n  \"message\": \"missing or malformed authorization header\"\n}\n```\n\nThis proves JWT protection works."
			}
		},
		{
			"name": "1️⃣3️⃣ Swagger UI (open in browser)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/swagger/index.html",
					"protocol": "http",
					"host": ["localhost"],
					"port": "8080",
					"path": ["swagger", "index.html"]
				},
				"description": "Opens the interactive Swagger UI.\n\nYou can also open this directly in your browser:\nhttp://localhost:8080/swagger/index.html"
			}
		}
	]
}
